# ===========================================
# LUXE Store - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit your .env file to version control
# ===========================================

# -------------------------------------------
# Database (SQLite - required)
# -------------------------------------------
DATABASE_URL=file:./db/custom.db

# -------------------------------------------
# NextAuth.js (required for authentication)
# -------------------------------------------
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# -------------------------------------------
# Stripe Payments (required for checkout)
# -------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# -------------------------------------------
# Redis (optional - caching & rate limiting)
# -------------------------------------------
REDIS_URL=redis://localhost:6379

# -------------------------------------------
# Email / SMTP (optional - order notifications)
# -------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@luxestore.sa
SMTP_PASSWORD=your-password
